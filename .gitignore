# macOS
.DS_Store

# Xcode / build
build/
dist/
DerivedData/
*.xcuserstate
xcuserdata/

# Generated by xcodegen — run `xcodegen generate` to recreate
Slate.xcodeproj/
Slate/Info.generated.plist
Slate/Slate.entitlements

# SwiftPM
.swiftpm/
.build/

# Python
__pycache__/
*.pyc

# Whisper models (large binaries — fetched, not committed)
pipeline/models/*.bin

# libass-enabled ffmpeg static binary (~25MB — fetched by pipeline/bin/install.sh)
pipeline/bin/ffmpeg

# Recording output (never commit takes)
*.slatebundle/
takes/

# Secrets — never commit (repo is public)
.env
.env.*
*.p8
*.pem
